@model IEnumerable<ClickParty.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="container">

    <div class="hero-section row">
        <div class="col s12 m6">
            <h1 class="hero-title">
                Click & <em class="hero-title-italic">Party</em>
            </h1>
            <p class="hero-subtitle">
                We don't just list events. We curate sensory experiences that
                define your journey. Explore the extraordinary.
            </p>
        </div>

        
    </div>
    
    <div class="row">

        @foreach (var ev in Model)
        {
            <div class="col s12 m6 l4">
                <div class="event-card">

                    <div class="event-card-img">
                        @if (!string.IsNullOrEmpty(ev.Image_url))
                        {
                            <img src="@ev.Image_url" alt="@ev.Title" />
                        }
                        else
                        {
                            <img src="https://via.placeholder.com/400x200/1a3d2b/ffffff?text=Event" alt="Event" />
                        }
                        <div class="event-badges">
                            <span class="badge-category">@ev.Category?.ToUpper()</span>
                        </div>
                        <div class="status-pill">
                            <span class="status-dot @(ev.Status?.ToLower() == "active" ? "" : "inactive")"></span>
                            @ev.Status?.ToUpper()
                        </div>

                    </div>

                    <div class="event-card-body">
                        <div class="event-date-label">
                            <i class="material-icons">calendar_today</i>
                            @ev.Date.ToString("MMM dd, yyyy").ToUpper()
                        </div>
                        <h3 class="event-card-title">@ev.Title</h3>
                        <p class="event-card-desc">
                            @(ev.Description?.Length > 100 ? ev.Description.Substring(0, 100) + "..." : ev.Description)
                        </p>
                        <div class="event-card-footer">
                            <span class="event-location">
                                <i class="material-icons">place</i>
                                @ev.Location
                            </span>

                            <a asp-controller="Events" asp-action="Show" asp-route-id="@ev.Id" class="event-action-link">
                                View Details <i class="material-icons" style="font-size:0.9rem">arrow_forward</i>
                            </a>
                        </div>

                    </div>

                </div>
            </div>
        }

    </div>

</div>